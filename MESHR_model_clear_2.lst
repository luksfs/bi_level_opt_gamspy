  81  SCALAR R_cost "Gas constant J K-1 kmol-1" /8.314463e3/;
  82  SCALAR Elapsed_time;
  83   
  84   
  85  PARAMETER jmax;
  86   
  87  SCALAR
  88   Tmin /330/
  89   Tmax /410/
