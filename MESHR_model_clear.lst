 989  cooling_cost = (0.378e-9*Qc.l) * 8150 * 60 * FH_factor;
 990  react_cost = (FE.l*CostEth + FB*CostBut)*F_factor* 8150 * 60;
 991  ETBE_rev = (- CostETBE*Breb.l)*F_factor* 8150 * 60;
 992   
 993   
 994  area_cond_par = (Qc.l*FH_factor/60) / ( (150/0.17611) * (10 / log((Tcond.l-303.15)/(Tcond.l-313.15))) ) * 10.7639;
 995  area_reb_par = (Qr.l*FH_factor/60) / ( (250/0.17611) * (433.15 - Treb.l) ) * 10.7639;
 996   
 997  tao_nrtl_par(i, k, j)$(ord(j) <= Ns) = b_nrtl(i,k) / T.l(j);
 998  g_nrtl_par(i, k, j)$(ord(j) <= Ns) = (exp(-c_nrtl(i,k) * ( b_nrtl(i,k) / T.l(j) ) ) );
 999  Xg_par(i, j)$(ord(j) <= Ns) = x.l(i,j)*gamma_nrtl.l(i,j);
1000   
1001  * ( x(i,j)*gamma_nrtl(i,j) )
1002  *$macro tao_nrtl(i,k,j)  ( b_nrtl(i,k) / T(j) )
1003  *$macro g_nrtl(i,k,j) (exp(-c_nrtl(i,k) * ( b_nrtl(i,k) / T(j) ) ) )
1004  *$macro Tr(i,j) ( T(j)/Tc(i) )
1005  *$macro Betav(j) ( b(j) * P(j) ) / ( R*T(j) )
1006  *$macro qv(j) ( a(j) / (b(j)*R*T(j) ) )
