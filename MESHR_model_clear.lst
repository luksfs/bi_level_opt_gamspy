  97   
  98  * ============================================================================ *
  99  * ============================= GIVEN PARAMETERS ============================= *
 100  * ============================================================================ *
 101   
 102  *SRK  - components propeerties 1- n-butene | CAS RN: 106-98-9 ;  2 - Ethanol | CAS RN: 64-17-5 ;  3 - Isobutene/Isobutylene | CAS RN: 115-11-7 ; 4 - ETBE - Ethyl tert-butyl ether | CAS RN: 637-92-3
 103   
 104  PARAMETER
 105   v_i(i)   "Stoichiometric coefficients" /1 0, 2 -1, 3 -1, 4 1/
 106   m_cat    "Catalyst mass (kg)" /0.4/
 107   zE(i)    "Molar fraction of ethanol" /1 0, 2 1, 3 0, 4 0/
 108   FB       "Butenes molar flowrate (mol/min)"
 109   zB(i)    "Molar fraction of butenes" /1 0.7, 2 0, 3 0.3, 4 0/
 110   R        "Universal gas constant (J/mol-K)" /8.314/
 111   Omega_a  "SRK parameter" /0.42747/
 112   Omega_b  "SRK parameter" /0.08664/
 113   Mw(i)    "Molecular weights (kg/kmol)" / 1 56.10752, 2 46.06904, 3 56.10752, 4 102.17656 /
 114   Pc(i)    "Critical pressure (Pa)"      / 1 4.02E6, 2 6.137E6, 3 4.0E6, 4 2.934E6 /
 115   Tc(i)    "Critical temperature (K)"    / 1 419.5, 2 514, 3 417.9, 4 509.4 /
 116   w(i)     "Acentric factor"             / 1 0.184495, 2 0.643558, 3 0.19484, 4 0.316231 /
 117   Tb(i)    "Boiling temperature (K)"     / 1 342.6, 2 421.5, 3 341.8, 4 441.4 /
 118   Hform(i) "Heat of formation (J/mol)"   / 1 -500, 2 -234950, 3 -17100, 4 -313900 /
 119   kappa(i) "SRK equation parameter"
 120   ac(i)    "Component-specific parameter"
 121   bii(i)   "SRK b-parameter"
 122   F_factor "Scaling factor (mol/min)"
 123   FH_factor  "Scaling factor for duty (J/min)"
 124   H_factor "Scaling factor for enthalpy (J/mol)"
 125   TF_factor "Scaling Temperature (K)"
 126  ;
 127   
 128  * ============================================================================ *
 129  * Enthalpy for two feeds
 130  * ============================================================================ *
 131   
 132  PARAMETERS
 133      HFB_d    "Enthalpy of butenos feed [J/mol]" /-21481.62933928521/
 134      HFE_d    "Enthalpy of ethanol feed [J/mol]" /-273241.2338487912/
 135      HFB      "Enthalpy of butenos feed [-]"
 136      HFE      "Enthalpy of ethanol feed [-]";
 137  SCALAR NFE "Ethanol feed stage", NFB "Butenes feed stage";
 138   
 139  *scaling factors
 140  F_factor = (1.7118+5.774);
 141  FH_factor = 1.7118*abs(HFE_d) + 5.774*abs(HFB_d);
 142  H_factor = F_factor/FH_factor;
 143  TF_factor = (342.38 + 325)/2;
 144   
 145  HFE = HFE_d*H_factor;
 146  HFB = HFB_d*H_factor;
 147  *Feed
 148  *FE = 1.7118/F_factor;
 149  FB = 5.774/F_factor;
 150   
 151  * Calculate component-specific parameters
 152  kappa(i) = 0.480 + 1.574*w(i) - 0.176*w(i)**2;
 153  ac(i) = Omega_a * (R * Tc(i)) ** 2 / Pc(i);
 154  bii(i) = Omega_b * R * Tc(i) / Pc(i);
 155   
 156  * ============================================================================ *
 157  * ================================= VARIABLES ================================ *
 158  * ============================================================================ *
 159   
 160  POSITIVE VARIABLES
 161      L(j)        "Liquid molar flowrate (mol/min)"
 162      V(j)        "Vapor molar flowrate (mol/min)"
 163      x(i,j)      "Liquid molar fraction"
 164      y(i,j)      "Vapor molar fraction"
 165      T(j)        "Temperature (K)"
 166      D           "Destillate product flowrate (mol/min)"
 167      Qc          "Condenser Duty (J/min)"
 168      Qr          "Reboiler Duty (J/min)"
 169      FE          "Ethanol molar flowrate"
 170  ;
 171   
 172   
 173  * ============================================================================ *
 174  * ================================= EQUATIONS ================================ *
 175  * ============================================================================ *
 176   
 177  EQUATION psat_def(i,j);
 178  *  Saturation Pressure expanded Antoine (Aspen data)
 179  POSITIVE VARIABLES logPsat(i,j) "Saturation Pressure (Pa)";
 180   
 181  PARAMETER kk(i,*) "psat antoine parameters";
 182  TABLE kk(i,*)
 183          1      2          3     4      5        6          7
 184  1    51.836  -4019.2      0     0   -4.5229   4.8833E-17   6
 185  2    73.304  -7122.3      0     0   -7.1424   2.8853E-06   2
 186  3    78.01   -4634.1      0     0   -8.9575   1.3413E-05   2
 187  4    64.188  -5820.2      0     0   -6.1343   2.1405E-17   6;
 188   
 189  psat_def(i,j)$(ord(j) <= Ns) ..
 190      logPsat(i,j) =E= (
 191           kk(i,'1') + kk(i,'2')/(kk(i,'3') + T(j))
 192           + kk(i,'4')*T(j) + kk(i,"5")*LOG(T(j))
 193           + kk(i,'6')*(T(j)**kk(i,'7')));
 194   
 195  * ============================================================================ *
 196  * Soave Redlich Kwong for Mixtures (phi_mix,HR_mix)
 197  * ============================================================================ *
 198  VARIABLES
 199      Z(j)          "Compressibility factor"
 200      v_mol(j)      "Molar volume"
 201      phi(i,j)      "Fugacity coefficient"
 202      HR(j)         "Residual enthalpy",
 203      alpha_ij(i,j) "Alpha parameter"
 204      aii(i,j)    "Component-wise SRK aii parameter"
 205      a(j)        "Mixture parameter a"
 206      b(j)        "Mixture parameter b"
 207      dadT_ii(i,j) "Partial derivative of a to T"
 208      dadT(j)     "Total temperature derivative of a";
 209   
 210  PARAMETER P(j) "Pressure (Pa)";
 211  * Assign the same value to all trays
 212  P(j) = 9.5e5;
 213   
 214  EQUATIONS
 215      cubic_eos,
 216      v_definition,
 217      fugacity_eq,
 218      enthalpy_eq,
 219      alpha_definition,
 220      aii_definition,
 221      mixing_rule_b,
 222      mixing_rule_a,
 223      dadT_ii_eq,
 224      dadT_eq;
 225   
 226  * Macro for make it easier to write the equations
 227  $macro Tr(i,j) ( T(j)/Tc(i) )
 228  $macro Betav(j) ( ( b(j) * P(j) ) / ( R*T(j) ) )
 229  $macro qv(j) ( a(j) / (b(j)*R*T(j) ) )
 230   
 231  * Complete model
 232  cubic_eos(j)$(ord(j) <= Ns)  ..
 233      -Z(j) + 1 + ( ( b(j) * P(j) ) / ( R*T(j) ) ) - ( a(j) / (b(j)*R*T(j) ) ) * ( ( b(j) * P(j) ) / ( R*T(j) ) ) * ( Z(j) - ( ( b(j) * P(j) ) / ( R*T(j) ) ) ) / ( Z(j)*( Z(j) + ( ( b(j) * P(j) ) / ( R*T(j) ) ) ) ) =E= 0;
 234   
 235  alpha_definition(i,j)$(ord(j) <= Ns)  ..
 236      alpha_ij(i,j) =E= ( 1 + kappa(i) * ( 1 - sqrt(( T(j)/Tc(i) )) )  )**2;
 237   
 238  aii_definition(i,j)$(ord(j) <= Ns)  ..
 239      aii(i,j) =E= alpha_ij(i,j) * ac(i);
 240   
 241  mixing_rule_b(j)$(ord(j) <= Ns)  ..
 242      b(j) =E= SUM(i, y(i,j) * bii(i));
 243   
 244  * Create an alias for set i
 245  ALIAS(i, k);
 246  mixing_rule_a(j)$(ord(j) <= Ns)  ..
 247      a(j) =E= SUM(i, SUM(k, y(i,j) * y(k,j) * sqrt(aii(i,j) * aii(k,j))));
 248   
 249  v_definition(j)$(ord(j) <= Ns)  ..
 250      v_mol(j) =E= Z(j)*R*T(j)/P(j);
 251   
 252  fugacity_eq(i,j)$(ord(j) <= Ns)  ..
 253      phi(i,j) =E= EXP(
 254          bii(i)*(Z(j)-1)/b(j) - log( P(j)*(v_mol(j)-b(j))/(R*T(j)) ) +
 255          (a(j)/(b(j)*R*T(j))) * ( bii(i)/b(j) - 2*SUM(k, y(k,j) * SQRT(aii(i,j) * aii(k,j)))/a(j)) * log((v_mol(j)+b(j))/v_mol(j))
 256      );
 257   
 258  dadT_ii_eq(i,j)$(ord(j) <= Ns)  ..
 259      dadT_ii(i,j) =E= -(ac(i) * kappa(i)) * sqrt(alpha_ij(i,j) * ( T(j)/Tc(i) )) / T(j);
 260   
 261  dadT_eq(j)$(ord(j) <= Ns)  ..
 262      dadT(j) =E= - SUM(i, SUM(k, y(i,j) * y(k,j) * sqrt(dadT_ii(i,j) * dadT_ii(k,j))));
 263   
 264  enthalpy_eq(j)$(ord(j) <= Ns)  ..
 265      HR(j) =E= R*T(j)*(Z(j)-1 + (T(j)*dadT(j) - a(j)) / (b(j)*R*T(j)) * log((v_mol(j) + b(j))/v_mol(j)));
 266   
 267  * ============================================================================ *
 268  * NRTL model
 269  * ============================================================================ *
 270   
 271  Parameters
 272      b_nrtl(i,i) /
 273          1.2  595.529982, 1.3 110.239086, 1.4 226.373398,
 274          2.1 164.57256,  2.3 141.963213, 2.4 187.104064,
 275          3.1 -95.4252161,3.2 623.581001, 3.4 219.73407,
 276          4.1 -177.88565, 4.2 344.481315, 4.3 -172.59152
 277      /
 278      c_nrtl(i,i) /
 279      1.1  0.0,  1.2  0.3,  1.3  0.3,  1.4  0.3,
 280      2.1  0.3,  2.2  0.0,  2.3  0.3,  2.4  0.3,
 281      3.1  0.3,  3.2  0.3,  3.3  0.0,  3.4  0.3,
 282      4.1  0.3,  4.2  0.3,  4.3  0.3,  4.4  0.0
 283      /;
 284   
 285   
 286  *Parameter a_nrtl(i,i);
 287  *a_nrtl(i,i) = 0
 288   
 289  Alias(i,k);
 290  Alias(i,h);
 291  Alias(i,m);
 292   
 293  Variables
 294      gamma_nrtl(i,j);
 295   
 296  Equations
 297      Compute_gamma(i,j), Compute_gamma_ideal(i,j);
 298   
 299  *calc_tao(i,k,j) ..
 300  *    tao_nrtl(i,k,j) =E= b_nrtl(i,k) / T(j);
 301   
 302  *calc_g(i,k,j)..
 303  *    g_nrtl(i,k,j) =E= exp(-c_nrtl(i,k) * tao_nrtl(i,k,j));
 304   
 305  $macro tao_nrtl(i,k,j)  ( b_nrtl(i,k) / T(j) )
 306  $macro g_nrtl(i,k,j) (exp(-c_nrtl(i,k) * ( b_nrtl(i,k) / T(j) ) ) )
 307   
 308  *Equation 29
 309  Compute_gamma(i,j)$(ord(j) <= Ns) ..
 310      gamma_nrtl(i,j) =E= exp(
 311          SUM(h, x(h,j) * ( b_nrtl(h,i) / T(j) ) * (exp(-c_nrtl(h,i) * ( b_nrtl(h,i) / T(j) ) ) )) /
 312          SUM(k, x(k,j) * (exp(-c_nrtl(k,i) * ( b_nrtl(k,i) / T(j) ) ) ))
 313      +
 314          SUM(h, (x(h,j) * (exp(-c_nrtl(i,h) * ( b_nrtl(i,h) / T(j) ) ) )) /
 315          SUM(k, x(k,j) * (exp(-c_nrtl(k,h) * ( b_nrtl(k,h) / T(j) ) ) )) *
 316          (( b_nrtl(i,h) / T(j) ) -
 317          SUM(m, x(m,j) * ( b_nrtl(m,h) / T(j) ) * (exp(-c_nrtl(m,h) * ( b_nrtl(m,h) / T(j) ) ) )) /
 318          SUM(k, x(k,j) * (exp(-c_nrtl(k,h) * ( b_nrtl(k,h) / T(j) ) ) ))))
 319          );
 320   
 321  * ============================================================================ *
 322  * Partiion coeffient
 323  * ============================================================================ *
 324   
 325  Positive Variable K_part(i,j);
 326   
 327  Equation K_equation(i,j);
 328   
 329  K_equation(i,j)$(ord(j) <= Ns)  ..
 330      K_part(i,j)*(phi(i,j) * P(j)) =E= gamma_nrtl(i,j) * exp(logPsat(i,j));
 331   
 332   
 333  * ============================================================================ *
 334  * Enthalpy vapor phase
 335  * ============================================================================ *
 336   
 337  SET cc /1*5/;
 338   
 339  PARAMETERS
 340      C_ig(i,cc) Heat capacity coefficients for ideal gas;
 341   
 342  TABLE C_ig(i,cc)
 343         1              2              3              4              5
 344  1  111.022862   -0.750243683  0.00374664805  -6.16980174E-06   3.65183052E-09
 345  2   78.1195715  -0.495919524  0.00257066991  -4.30332398E-06   2.57806954E-09
 346  3  150.319619   -0.966221476  0.00404410804  -6.00376885E-06   3.23582716E-09
 347  4   47.4579586  -0.349114826  0.00180207897  -3.04885369E-06   1.83440907E-09;
 348   
 349   
 350  SCALAR T0 "Reference temperature [K]" /298.15/;
 351   
 352  VARIABLES DH_ig(i,j) "Ideal gas enthalpy change [J/mol]";
 353  VARIABLES Hvi(i,j) "Ideal gas enthlapy of vapor phase for component i + Hform[J/mol]";
 354  VARIABLES Hv(j) "Total vapor phase enthalpy";
 355  *VARIABLES DH_ig_2(i,j);
 356   
 357  EQUATIONS calc_DH_ig, calc_Hvi, calc_Hv;
 358   
 359  calc_DH_ig(i,j) $(ord(j) <= Ns) ..
 360      DH_ig(i,j) =E= (C_ig(i,'1')*(T(j) - T0)
 361                 + C_ig(i,'2')*(T(j)**2 - T0**2)/2
 362                 + C_ig(i,'3')*(T(j)**3 - T0**3)/3
 363                 + C_ig(i,'4')*(T(j)**4 - T0**4)/4
 364                 + C_ig(i,'5')*(T(j)**5 - T0**5)/5);
 365   
 366  calc_Hvi(i,j) $(ord(j) <= Ns) ..
 367      Hvi(i,j) =E= DH_ig(i,j) + Hform(i);
 368   
 369  calc_Hv(j)$(ord(j) <= Ns) ..
 370      Hv(j)/H_factor =E= (sum(i, y(i,j) * Hvi(i,j)) + HR(j));
 371   
 372   
 373  * ============================================================================ *
 374  * Enthalpy liquid phase
 375  * ============================================================================ *
 376  PARAMETERS
 377      C_liq(i,cc) Heat capacity coefficients for liquid phase,
 378      C_vap(i,cc) DIPPR coefficients for vaporization enthalpy;
 379   
 380  TABLE C_liq(i,cc)
 381         1              2              3                  4                   5
 382  1  2.42239762e+05  -2.74746461e+03   1.16801221e+01  -2.20506997e-02   1.56048214e-05
 383  2  1.21280234e+03  -1.30223888e+01   5.71358761e-02  -1.12370042e-04   8.73258381e-08
 384  3  3.08689696e+05  -3.49815711e+03   1.48572135e+01  -2.80226414e-02   1.98131733e-05
 385  4  1.20736602e+03  -1.29812644e+01   5.93572571e-02  -1.16271343e-04   8.66983296e-08;
 386   
 387  TABLE C_vap(i,cc)
 388         1          2      3          4         5
 389  1   33774     0.5107    -0.17304   0.05181    0
 390  2   65831     1.1905    -1.7666    1.0012     0
 391  3   43172     1.5334    -1.9       0.83816    0
 392  4   45290     0.27343    0.21645  -0.11756    0;
 393   
 394  Parameter Tbr(i)
 395            alpha_Tb(i)
 396            ai_Tb
 397            e
 398            sigma
 399            ;
 400  Tbr(i) = Tb(i)/Tc(i);
 401   
 402  Parameter DH_vap(i) "Vaporization enthalpy at Tb [J/mol]";
 403  DH_vap(i) = C_vap(i,'1')*(1 - Tbr(i))**(C_vap(i,'2')
 404              + C_vap(i,'3')*Tbr(i)
 405              + C_vap(i,'4')*Tbr(i)**2
 406              + C_vap(i,'5')*Tbr(i)**3);
 407   
 408  Parameter DH_ig_Tb(i) "DH_ig from T0 to TB [J/mol]";
 409  DH_ig_Tb(i) = C_ig(i,'1')*(Tb(i) - T0)
 410                 + C_ig(i,'2')*(sqr(Tb(i)) - sqr(T0))/2
 411                 + C_ig(i,'3')*(power(Tb(i),3) - power(T0,3))/3
 412                 + C_ig(i,'4')*(power(Tb(i),4) - power(T0,4))/4
 413                 + C_ig(i,'5')*(power(Tb(i),5) - power(T0,5))/5;
 414   
 415  VARIABLES DH_liq(i,j) "Liquid enthalpy change from Tb to T [J/mol]";
 416  VARIABLES Hv_Tbi_P(i,j) "Vapor phase enthalpy at Tb [J/mol]";
 417  VARIABLES Hli(i,j) "Liquid enthalpy for each component [J/mol]";
 418  VARIABLES Hl(j) "Total liquid phase enthalpy [J/mol]";
 419  * SRK for pure components at Tb
 420  * Define the equation for Z_vi
 421   
 422  alpha_Tb(i) = (1 + kappa(i) * (1 - Tbr(i) ** 0.5)) ** 2;
 423  ai_Tb(i) = alpha_Tb(i)*ac(i);
 424   
 425  *Cubic EOS - SRK
 426   
 427  e = 0;
 428  sigma = 1;
 429   
 430  Positive Variable Zvi(i,j), v_mol_i(i,j);
 431  Equation Zvi_eq(i,j), v_eq(i,j);
 432  Variable  HR_pure(i,j) "Residual enthalpy for pure substance";
 433   
 434  $macro Betav_p(i,j) ( bii(i)*P(j)/(R*Tb(i)) )
 435  $macro qv_p(i) ( ai_Tb(i) / (bii(i)*R*Tb(i)) )
 436   
 437  Zvi_eq(i,j) $(ord(j) <= Ns) ..
 438      -Zvi(i,j) + 1 + ( bii(i)*P(j)/(R*Tb(i)) ) -
 439      ( ai_Tb(i) / (bii(i)*R*Tb(i)) ) * ( bii(i)*P(j)/(R*Tb(i)) ) * ( Zvi(i,j) - ( bii(i)*P(j)/(R*Tb(i)) ) ) / ( Zvi(i,j)*( Zvi(i,j) + ( bii(i)*P(j)/(R*Tb(i)) ) ) ) =E= 0;
 440   
 441  v_eq(i,j) $(ord(j) <= Ns) ..
 442      v_mol_i(i,j) =E= Zvi(i,j)*R*Tb(i)/P(j);
 443   
 444  Variable  HR_pure(i,j);
 445  Parameter dadT_Tb(i);
 446  Equation calc_HR_pure(i,j);
 447   
 448  dadT_Tb(i) = - ac(i)*kappa(i)*sqrt(alpha_Tb(i)*Tbr(i))/Tb(i);
 449   
 450  calc_HR_pure(i,j) $(ord(j) <= Ns) ..
 451      HR_pure(i,j) =E= R * Tb(i) * (Zvi(i,j) - 1 + (Tb(i) * dadT_Tb(i) - ai_Tb(i)) / (bii(i) * R * Tb(i)) * log((v_mol_i(i,j) + bii(i)) / v_mol_i(i,j)));
 452   
 453   
 454  EQUATIONS calc_DH_liq, calc_Hli, calc_Hl, calc_Hv_Tbi_P(i,j);
 455   
 456  calc_DH_liq(i,j) $(ord(j) <= Ns) ..
 457          DH_liq(i,j) =e= C_liq(i,'1')*(T(j) - Tb(i))
 458          + C_liq(i,'2')*(T(j)**2 - Tb(i)**2)/2
 459          + C_liq(i,'3')*(T(j)**3 - Tb(i)**3)/3
 460          + C_liq(i,'4')*(T(j)**4 - Tb(i)**4)/4
 461          + C_liq(i,'5')*(T(j)**5 - Tb(i)**5)/5;
 462   
 463  calc_Hv_Tbi_P(i,j) $(ord(j) <= Ns) ..
 464      Hv_Tbi_P(i,j) =E= DH_ig_Tb(i) + Hform(i) + HR_pure(i,j);
 465   
 466  calc_Hli(i,j) $(ord(j) <= Ns) ..
 467      Hli(i,j) =E= DH_liq(i,j) + Hv_Tbi_P(i,j) - DH_vap(i);
 468   
 469  calc_Hl(j)$(ord(j) <= Ns) ..
 470      Hl(j)/H_factor =E= sum(i, x(i,j) * Hli(i,j));
 471   
 472  * ============================================================================ *
 473  * Chemical reaction rate
 474  * ============================================================================ *
 475  *SETS
 476  *   reactive_trays(j) "Reactive trays"  /3,4,5 /
 477   
 478  PARAMETER  reactive_trays(j);
 479   
 480  *reactive_trays(j)$(ord(j) = NR) = 1;
 481  *reactive_trays(j)$(ord(j) = NR+1) = 1;
 482  *reactive_trays(j)$(ord(j) = NR+2) = 1;
 483   
 484   
 485  VARIABLES
 486      K_eq(j) "Reaction equilibrium constant"
 487      k_rate(j) "Specific reaction rate [mol/(kg_cat-min)]"
 488      k_A(j) "Adsorption rate"
 489      Rxn_Rate(j) "Reaction rate [mol/(kg_cat-min)]";
 490   
 491   
 492  $macro Xg(i,j) ( x(i,j)*gamma_nrtl(i,j) )
 493   
 494  * Reaction equilibrium constant
 495  EQUATION calc_K_eq(j);
 496  calc_K_eq(j)$((ord(j) = NR1) OR (ord(j) = NR2) OR (ord(j) = NR3)) ..
 497      K_eq(j) =E= EXP(10.387 + 4060.59/T(j) - 2.89055*LOG(T(j))
 498                  - 0.01915144*T(j) + 5.28586E-5*T(j)**2 - 5.32977E-8*T(j)**3);
 499   
 500  * Specific reaction rate
 501  EQUATION calc_k_rate(j);
 502  calc_k_rate(j)$((ord(j) = NR1) OR (ord(j) = NR2) OR (ord(j) = NR3)) ..
 503      k_rate(j) =E= 7.41816E15 * EXP(-60.4E3 / (R * T(j))) / 60;
 504   
 505  * Adsorption rate
 506  EQUATION calc_k_A(j);
 507  calc_k_A(j)$((ord(j) = NR1) OR (ord(j) = NR2) OR (ord(j) = NR3)) ..
 508      k_A(j) =E= EXP(-1.0707 + 1323.1 / T(j));
 509   
 510  * Reaction rate equation
 511  EQUATION calc_Rx_Rate(j);
 512  calc_Rx_Rate(j)$((ord(j) = NR1) OR (ord(j) = NR2) OR (ord(j) = NR3)) ..
 513  *    Rxn_Rate(j)*K_eq(j)*Xg('2',j) =E= k_rate(j)*(Xg('2',j))**2*(Xg('3',j)*K_eq(j)*Xg('2',j) - Xg('4',j))/(1+k_A(j)*Xg('2',j))**3;
 514      Rxn_Rate(j) =E= k_rate(j)*( x('2',j)*gamma_nrtl('2',j) ) * ( ( x('2',j)*gamma_nrtl('2',j) ) * ( x('3',j)*gamma_nrtl('3',j) ) - ( x('4',j)*gamma_nrtl('4',j) )/K_eq(j) ) / (1 + k_A(j)*( x('2',j)*gamma_nrtl('2',j) ) )**3;
 515   
 516  * Set reaction rate to zero for non-reactive trays
 517  EQUATION assign_zero(j);
 518  assign_zero(j)$((ord(j) <> NR1) AND (ord(j) <> NR2) AND (ord(j) <> NR3)) ..
 519     Rxn_Rate(j) =E= 0;
 520   
 521   
 522  * ============================================================================ *
 523  * MESHR model
 524  * ============================================================================ *
 525   
 526  EQUATIONS mol_balance_eq(j), mol_balance_condenser_eq, mol_balance_reboiler_eq,
 527            comp_balance_eq(i,j), comp_balance_condenser_eq(i), comp_balance_reboiler_eq(i,j),
 528            eq_rel_eq(i,j), summation_eq(j), energy_balance_eq(j), energy_balance_condenser_eq,
 529            energy_balance_reboiler_eq(j), spec_1_eq(j), spec_2_eq(j);
 530   
 531  Parameters
 532  *Spec_1 "Reflux ratio" /3/
 533  *Spec_2 "Bottom to feed ratio" /0.233/;
 534   
 535  Spec_1 "Ethanol conversion" /0.85/
 536  Spec_2 "ETBE molar fraction on the bottom produtct" /0.83/;
 537   
 538  * Total Molar Balance
 539  mol_balance_eq(j)$((ord(j) GT 1) AND (ord(j) LT Ns)) ..
 540      L(j) + V(j) - V(j+1) - L(j-1)
 541      - FE$(ord(j) EQ NFE)
 542      - FB$(ord(j) EQ NFB)
 543      - SUM(i, v_i(i) * m_cat * Rxn_Rate(j))/F_factor =E= 0;
 544   
 545  * Special case for the condenser (first stage)
 546  mol_balance_condenser_eq ..
 547      V('1') + (L('1') + D) - V('2') =E= 0;
 548   
 549  * Special case for the reboiler (last stage)
 550  *mol_balance_reboiler_eq ..
 551  *    V('10') + L('10') - L('9') =E= 0;
 552   
 553  * Special case for the reboiler (last stage)
 554  mol_balance_reboiler_eq(j)$(ord(j) EQ Ns) ..
 555      V(j) + L(j) - L(j-1) =E= 0;
 556   
 557  * Component Molar Balance
 558  comp_balance_eq(i,j)$((ord(j) GT 1) AND (ord(j) LT Ns)) ..
 559          L(j) * x(i,j) + V(j) * y(i,j) - V(j+1) * y(i,j+1) - L(j-1) * x(i,j-1)
 560         - FE$(ord(j) EQ NFE) * zE(i) - FB$(ord(j) EQ NFB) * zB(i) - m_cat * v_i(i) * Rxn_Rate(j)/F_factor =E= 0;
 561   
 562  * Special case for component balance in the condenser
 563  comp_balance_condenser_eq(i) ..
 564      V('1') * y(i,'1') + (L('1') + D) * x(i,'1') - V('2') * y(i,'2') =E= 0;
 565   
 566  * Special case for component balance in the reboiler
 567  *comp_balance_reboiler_eq(i) ..
 568  *    V('10') * y(i,'10') + L('10') * x(i,'10') - L('9') * x(i,'9') =E= 0;
 569   
 570  * Special case for component balance in the reboiler
 571  comp_balance_reboiler_eq(i,j)$(ord(j) EQ Ns) ..
 572      V(j) * y(i,j) + L(j) * x(i,j) - L(j-1) * x(i,j-1) =E= 0;
 573   
 574  * Equilibrium Relations
 575  eq_rel_eq(i,j) $(ord(j) <= Ns) ..
 576      K_part(i,j) * x(i,j) - y(i,j) =E= 0;
 577   
 578  * Summation Constraint
 579  summation_eq(j) $(ord(j) <= Ns) ..
 580      SUM(i, y(i,j) - x(i,j)) =E= 0;
 581   
 582  * Energy Balance
 583  energy_balance_eq(j)$((ord(j) GT 1) AND (ord(j) LT Ns)) ..
 584      V(j) * Hv(j) + L(j) * Hl(j) - V(j+1) * Hv(j+1) - L(j-1) * Hl(j-1) - FE$(ord(j) EQ NFE)*HFE - FB$(ord(j) EQ NFB)*HFB
 585      =E= 0;
 586   
 587  * Special case for the condenser energy balance
 588  energy_balance_condenser_eq ..
 589      V('1') * Hv('1') + (L('1') + D) * Hl('1') - V('2') * Hv('2') + Qc =E= 0;
 590   
 591  * Special case for the reboiler energy balance
 592  *energy_balance_reboiler_eq ..
 593  *   V('10') * Hv('10') + L('10') * Hl('10') - L('9') * Hl('9') - Qr =E= 0;
 594   
 595  * Special case for the reboiler energy balance
 596  energy_balance_reboiler_eq(j)$(ord(j) EQ Ns) ..
 597      V(j) * Hv(j) + L(j) * Hl(j) - L(j-1) * Hl(j-1) - Qr =E= 0;
 598   
 599  * Specifications
 600  *spec_1_eq(j)$(ord(j) EQ Ns) .. (FE - D*x['2','1'] - L[j]*x['2',j])/FE - Spec_1 =E= 0;
 601  *spec_2_eq(j)$(ord(j) EQ Ns) .. Spec_2 - x['4', j] =E= 0;
 602  *spec_1_eq(j)$(ord(j) EQ Ns)  .. (FE - D*x['2','1'] - L[j]*x['2',j])/FE  =E= Spec_1;
 603  *  molar flowarate spec
 604  spec_2_eq(j)$(ord(j) EQ Ns)  .. x['4', j] =E= Spec_2;
 605   
 606  * Specifications
 607  *spec_1_eq .. (FE - D*x['2','1'] - L['10']*x['2','10'])/FE  =g= Spec_1;
 608  *spec_2_eq .. x['4', '10'] =g= Spec_2;
 609   
 610  *spec_1_eq .. D - L['1']/Spec_1 =E= 0;
 611  *spec_2_eq .. (FE+FB)*Spec_2 - L['10'] =E= 0;
 612   
 613  equation V1_eq;
 614  V1_eq .. V('1') =E= 0;
 615   
 616  * ============================================================================ *
 617  * Column Diameter Calculation
 618  * ============================================================================ *
 619  VARIABLE
 620      D_col(j)        'Column diameter (ft)'
 621      Dcol_max        'Maximum column diameter (ft)'
 622      Mw_mix(j)       'Molecular weights (kg/kmol)';
 623   
 624  EQUATION
 625      def_D_col(j)    'Equation for column diameter calculation'
 626      def_Mw_mix(j)   'Define mixture molar mass at stage j'
 627      def_Dcol_max(j) 'Equation for maximum column diameter calculation';
 628   
 629  SCALAR FF 'Parameter for flooding velocity estimation - Douglas book #kg^1/2 m^-1/2 s^-1 '; ;
 630  FF = 1.51*(0.45359237/0.3048)**0.5;
 631   
 632  def_Mw_mix(j)$(ord(j) <= Ns) ..
 633      Mw_mix(j) =E= sum( i, y(i,j)*Mw(i) );
 634   
 635  * Expanding the macros into the equation safely
 636  def_D_col(j)$( (ord(j) > 1) AND (ord(j) < Ns) ) ..
 637      D_col(j) =E= sqrt(4 * ( (V(j)*F_factor*v_mol(j)/60) / ( (FF/sqrt(Mw_mix(j)*1e-3/v_mol(j))) * 0.88 ) ) / Pi) * 3.28084;
 638   
 639  def_Dcol_max(j)$( (ord(j) > 1) AND (ord(j) < Ns) ) ..
 640      Dcol_max =G= D_col(j);
 641   
 642  * ============================================================================ *
 643  * Equipment Costs & Economics (Refactored for NLP)
 644  * ============================================================================ *
 645  SCALAR MS "Marshall & Swift Parameter" /1773.4/;
 646   
 647  PARAMETERS
 648      CostETBE "Price of ETBE bottom product [$/mol]" / 25.3e-3 /
 649      CostEth  "Price of Ethanol [$/mol]"             / 15.0e-3 /
 650      CostBut  "Price of Butenes [$/mol]"             / 8.25e-3 /
 651      c_steam  "Steam cost parameter [$/J]"           / 4.54e-9 /;
 652   
 653  VARIABLES
 654      Tcond         "Condenser temperature (K)"
 655      Treb          "Reboiler Temperature (K)"
 656      Breb          "Bottoms flowrate"
 657      v_AreaCond    "Condenser heat transfer area (ft2)"
 658      v_AreaReb     "Reboiler heat transfer area (ft2)"
 659      v_ColCost     "Column shell cost ($)"
 660      v_TrayCost    "Tray cost ($)"
 661      v_CondCost    "Condenser cost ($)"
 662      v_RebCost     "Reboiler cost ($)"
 663      CAP_cost      "Capital cost ($/yr)"
 664      OP_cost       "Operational cost ($/yr)"
 665      Profit        "Annual Profit (Millions $)";
 666   
 667  EQUATIONS
 668      def_Tcond, def_Treb(j), def_Breb(j),
 669      eq_AreaCond, eq_AreaReb,
 670      eq_ColCost, eq_TrayCost, eq_CondCost, eq_RebCost,
 671      eq_CAP_cost, eq_OP_cost, def_Profit;
 672   
 673   
 674  * --- CRITICAL BOUNDS TO PREVENT SOLVER CRASHES ---
 675   
 676  def_Tcond ..
 677      Tcond =E= T('1');
 678   
 679  def_Treb(j)$(ord(j) = Ns) ..
 680      Treb =E= T(j);
 681   
 682  def_Breb(j)$(ord(j) = Ns) ..
 683      Breb =E= L(j);
 684   
 685  * Area Calculations
 686  * eq_AreaCond ..
 687  *     v_AreaCond =E= (Qc*FH_factor/60) / ( (150/0.17611) * (10 / log((Tcond-303.15)/(Tcond-313.15))) ) * 10.7639;
 688   
 689  * eq_AreaReb ..
 690  *     v_AreaReb =E= (Qr*FH_factor/60) / ( (250/0.17611) * (433.15 - Treb) ) * 10.7639;
 691   
 692  * Capital Costs
 693  eq_ColCost ..
 694      v_ColCost =E= (MS/280) * ( 101.9 * (Dcol_max**1.066) * ((0.7315*(Ns-2)*3.28084)**0.802) * 7.05 );
 695   
 696  eq_TrayCost ..
 697      v_TrayCost =E= (MS/280) * ( 4.7 * (Dcol_max**1.55) * (0.7315*(Ns-2)*3.28084) * 2.7 );
 698   
 699  eq_CondCost ..
 700      v_CondCost =E= (Qc*FH_factor/60/(150/0.17611 * ((10)/log((Tcond-303.15)/(Tcond-313.15))))*10.7639)**.65*1709.8394439285714;
 701   
 702  eq_RebCost ..
 703      v_RebCost =E= (MS/280*101.3*(( Qr*FH_factor/60/((250/0.17611)*(433.15-Treb))*10.7639)**.65*7.3525));
 704   
 705  eq_CAP_cost ..
 706      CAP_cost =E= (1/3) * (v_TrayCost + v_ColCost + v_CondCost + v_RebCost + (7.7*3*0.4));
 707   
 708  * Operational Costs
 709  eq_OP_cost ..
 710      OP_cost =E= (0.378e-9*Qc + c_steam*Qr) * 8150 * 60 * FH_factor +
 711                  (FE*CostEth + FB*CostBut - CostETBE*Breb) * F_factor * 8150 * 60;
 712   
 713  * Objective Function
 714  def_Profit ..
 715      Profit * 1e6 =E= CAP_cost + OP_cost;
 716   
 717  EQUATION obj_def;
 718  VARIABLE obj;
 719   
 720  obj_def ..
 721  *        obj =E= Qr + Dcol_max;
 722      obj =E= Profit;
 723   
 724  *test
 725  Parameter
 726      tao_nrtl_par(i, k, j)
 727      g_nrtl_par(i, k, j)
 728      Xg_par(i, j)
 729   
 730      qv_par(j)
 731      Betav_par(j)
 732      Tr_par(i, j);
 733   
 734  MODEL MESHR_Rigorous /
 735  psat_def,
 736  cubic_eos,
 737  v_definition,
 738  fugacity_eq,
 739  enthalpy_eq,
 740  alpha_definition,
 741  aii_definition,
 742  mixing_rule_b,
 743  mixing_rule_a,
 744  dadT_ii_eq,
 745  dadT_eq,
 746  Compute_gamma,
 747  K_equation,
 748  calc_DH_ig,
 749  calc_Hvi,
 750  calc_Hv,
 751  Zvi_eq,
 752  v_eq,
 753  *dadT_Tb_eq,
 754  calc_HR_pure,
 755  calc_DH_liq,
 756  calc_Hli,
 757  calc_Hl,
 758  calc_Hv_Tbi_P,
 759  calc_K_eq,
 760  calc_k_rate,
 761  calc_k_A,
 762  calc_Rx_Rate,
 763  assign_zero,
 764  mol_balance_eq,
 765  mol_balance_condenser_eq,
 766  mol_balance_reboiler_eq,
 767  comp_balance_eq,
 768  comp_balance_condenser_eq,
 769  comp_balance_reboiler_eq,
 770  eq_rel_eq,
 771  summation_eq,
 772  energy_balance_eq,
 773  energy_balance_condenser_eq,
 774  energy_balance_reboiler_eq,
 775  *spec_1_eq,
 776  spec_2_eq,
 777  V1_eq,
 778  def_D_col,
 779  def_Mw_mix,
 780  def_Dcol_max,
 781  def_Profit,
 782  def_Treb,
 783  def_Tcond,
 784  def_Breb,
 785  eq_ColCost,
 786  eq_TrayCost,
 787  eq_CondCost,
 788  eq_RebCost,
 789  eq_CAP_cost,
 790  eq_OP_cost,
 791  *CAP_eq,
 792  *OP_eq,
 793  obj_def
 794  /;
 795   
 796  * Positive Variables
 797  L.lo(j) = 1e-5 ;  L.up(j) = 50; L.l(j) = .5;
 798  V.lo(j) = 1e-5 ;  V.up(j) = 50; V.l(j) = .5;
 799  V.lo('1') = 0; V.up('1') = 0.001; V.l('1') = 0;
 800  x.lo(i,j) = 0;  x.up(i,j) = 1; x.l(i,j) = 0.25;
 801  y.lo(i,j) = 0;  y.up(i,j) = 1; y.l(i,j) = 0.25;
 802  D.lo = 0.01; D.up = 1;
 803  Qc.lo = 0.01;  Qc.up = 10;
 804  Qr.lo = 0.01;  Qr.up = 10;
 805  Breb.lo = 0.001; Breb.up = 1;
 806  T.lo(j) = Tmin; T.up(j) = Tmax; T.scale(j) = TF_factor;
 807   
 808  logPsat.lo(i,j) = (
 809                  kk(i,'1') + kk(i,'2')/(kk(i,'3') + Tmin)
 810                 + kk(i,'4')*Tmin + kk(i,"5")*LOG(Tmin)
 811                 + kk(i,'6')*(Tmin**kk(i,'7')));
 812   
 813   
 814  logPsat.up(i,j) = (
 815                  kk(i,'1') + kk(i,'2')/(kk(i,'3') + Tmax)
 816                 + kk(i,'4')*Tmax + kk(i,"5")*LOG(Tmax)
 817                 + kk(i,'6')*(Tmax**kk(i,'7')));
 818  logPsat.scale(i,j) = 10;
 819   
 820  * Apply linear profile
 821  *    jmax = Ns;
 822  *    T.L(j) = Tmin + (ord(j) - jmin) / (jmax - jmin) * (Tmax - Tmin);
 823  *                    T.L(j) = Tmin + (ord(j) - jmin) / (jmax - jmin) * (Tmax - Tmin);
 824   
 825  * SRK parameters and properties
 826  *dadT_Tb.lo(i) = -0.01; dadT_Tb.up(i) = -0.00001;
 827   
 828  alpha_ij.lo(i,j) = 0.5;  alpha_ij.up(i,j) = 2;
 829  aii.lo(i,j) = 1;  aii.up(i,j) = 4;
 830  a.lo(j) = 1;  a.up(j) = 3;
 831  b.lo(j) = 1e-5;  b.up(j) = 1e-3; b.scale(j) = 1e-5;
 832  dadT_ii.lo(i,j) = -0.009;  dadT_ii.up(i,j) = -0.001; dadT_ii.scale(i,j) = 1e-3;
 833  dadT.lo(j) = -0.009;  dadT.up(j) = -0.001; dadT.scale(j) = 1e-3;
 834  K_part.lo(i,j) = 0.001 ; K_part.up(i,j) = 10;
 835  phi.lo(i,j) = 0.1; phi.up(i,j) = 1.2;
 836   
 837  *    *Enthalpy Variables
 838  DH_ig.lo(i,j) = (C_ig(i,'1')*(Tmin - T0)
 839                 + C_ig(i,'2')*(Tmin**2 - T0**2)/2
 840                 + C_ig(i,'3')*(Tmin**3 - T0**3)/3
 841                 + C_ig(i,'4')*(Tmin**4 - T0**4)/4
 842                 + C_ig(i,'5')*(Tmin**5 - T0**5)/5);
 843  DH_ig.up(i,j) = (C_ig(i,'1')*(Tmax - T0)
 844                 + C_ig(i,'2')*(Tmax**2 - T0**2)/2
 845                 + C_ig(i,'3')*(Tmax**3 - T0**3)/3
 846                 + C_ig(i,'4')*(Tmax**4 - T0**4)/4
 847                 + C_ig(i,'5')*(Tmax**5 - T0**5)/5);
 848  DH_ig.scale(i,j) = 1e3;
 849   
 850  Hvi.lo(i,j) = DH_ig.lo(i,j) + Hform(i);
 851  Hvi.up(i,j) = DH_ig.up(i,j) + Hform(i);
 852  Hvi.scale(i,j) = 1e5;
 853   
 854  HR.lo(j) = -2500;  HR.up(j) = -1100; HR.scale(j) = 1e3;
 855   
 856  Hv.lo(j) = ( smin(i, Hvi.lo(i,j)) + HR.lo(j) ) * H_factor;
 857  Hv.up(j) = ( smax(i, Hvi.up(i,j)) + HR.up(j) ) * H_factor;
 858   
 859   
 860  DH_liq.lo(i,j) = C_liq(i,'1')*(Tmin - Tb(i))
 861                  + C_liq(i,'2')*(Tmin**2 - Tb(i)**2)/2
 862                  + C_liq(i,'3')*(Tmin**3 - Tb(i)**3)/3
 863                  + C_liq(i,'4')*(Tmin**4 - Tb(i)**4)/4
 864                  + C_liq(i,'5')*(Tmin**5 - Tb(i)**5)/5;
 865  DH_liq.up(i,j) = C_liq(i,'1')*(Tmax - Tb(i))
 866                  + C_liq(i,'2')*(Tmax**2 - Tb(i)**2)/2
 867                  + C_liq(i,'3')*(Tmax**3 - Tb(i)**3)/3
 868                  + C_liq(i,'4')*(Tmax**4 - Tb(i)**4)/4
 869                  + C_liq(i,'5')*(Tmax**5 - Tb(i)**5)/5;
 870  DH_liq.scale(i,j) = 1e4;
 871   
 872  HR_pure.lo(i,j) = -3e3;  HR_pure.up(i,j) = -1e3; HR_pure.scale(i,j) = 1e3;
 873  Hv_Tbi_P.lo(i,j) = DH_ig_Tb(i)*0.99 + Hform(i) + HR_pure.lo(i,j);
 874  Hv_Tbi_P.up(i,j) = DH_ig_Tb(i)*1.01 + Hform(i) + HR_pure.up(i,j);
 875  Hv_Tbi_P.scale(i,j) = 1e4;
 876   
 877  Hli.lo(i,j) = DH_liq.lo(i,j) + Hv_Tbi_P.lo(i,j) - DH_vap(i);
 878  Hli.up(i,j) = DH_liq.up(i,j) + Hv_Tbi_P.up(i,j) - DH_vap(i);
 879  Hli.scale(i,j) = 1e5;
 880   
 881  Hl.lo(j) = smin(i, Hvi.lo(i,j)) * H_factor;
