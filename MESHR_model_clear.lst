   2   
   3  * ============================================================================ *
   4  * =================================== SETS =================================== *
   5  * ============================================================================ *
   6  SET
   7      i "Number of components" /1*4/
   8      j "Number of stages"  /1*22/
   9   
  10  * New set for configurations instead of 7 nested sets to save memory
  11      config "Total number of valid structural combinations" / c1*c50000 /
  12  ;
  13   
  14  * ============================================================================ *
  15  * ============================= Discrete Variables ============================= *
  16  * ============================================================================ *
  17   
  18  SCALAR
  19      Nc "Total number of components" /4/
  20      Ns "Total number of stages"
  21      NR "First reactive tray"
  22      NFE "Ethanol feed stage"
  23      NFB "Butenes feed stage"
  24      NR1 "First reactive tray"
  25      NR2 "Second reactive tray"
  26      NR3 "Third reactive tray"
  27      nsmin /5/
  28      nsmax /22/
  29      count_s /0/
  30      count_f /0/
  31  ;
  32   
  33  * ============================================================================ *
  34  * ============================= Solution Parameters ============================= *
  35  * ============================================================================ *
  36   
  37  PARAMETER Config_Map(config, *) "Stores Ns, NFE, NFB, NR1, NR2, NR3 for each run";
  38   
  39  * Define result storage parameters with 2 dimensions instead of 7
  40  PARAMETERS
  41      Z_cost(config,j)
  42      v_mol_cost(config,j)
  43      Mw_cost(config,j)
  44      T_cost(config,j)
  45      V_cost(config,j)
  46      L_cost(config,j)
  47      D_col_arr(config,j)
  48      x_column(config,i,j)
  49      y_column(config,i,j)
  50   
  51  * Scalar results (one value per configuration)
  52      Qr_cost(config)
  53      Qc_cost(config)
  54      Treb_cost(config)
  55      Tcond_cost(config)
  56      RR_array(config)
  57      x_ETBE_array(config)
  58      x_ETBE_D_array(config)
  59      X_EtOH_array(config)
  60      profit_obj(config)
  61      Breb_cost(config)
  62   
  63      D_colMax_arr(config)
  64      FE_array(config)
  65   
  66      Mw_mix_temp(j)
  67      X_ETOH_j(j)
  68      X_D_ETBE_j(j)
  69      RR
  70      Tcond_t
  71  ;
  72   
  73  SCALAR R_cost "Gas constant J K-1 kmol-1" /8.314463e3/;
  74  SCALAR Elapsed_time;
  75   
  76  PARAMETER jmax;
  77   
  78  SCALAR
  79   Tmin /330/
  80   Tmax /410/
  81   jmin /1/;
  82   
  83  * ============================================================================ *
  84  * ============================= GIVEN PARAMETERS ============================= *
  85  * ============================================================================ *
  86   
  87  *SRK  - components propeerties 1- n-butene | CAS RN: 106-98-9 ;  2 - Ethanol | CAS RN: 64-17-5 ;  3 - Isobutene/Isobutylene | CAS RN: 115-11-7 ; 4 - ETBE - Ethyl tert-butyl ether | CAS RN: 637-92-3
  88   
  89  PARAMETER
  90   v_i(i)   "Stoichiometric coefficients" /1 0, 2 -1, 3 -1, 4 1/
  91   m_cat    "Catalyst mass (kg)" /0.4/
  92   zE(i)    "Molar fraction of ethanol" /1 0, 2 1, 3 0, 4 0/
  93   FB       "Butenes molar flowrate (mol/min)"
  94   zB(i)    "Molar fraction of butenes" /1 0.7, 2 0, 3 0.3, 4 0/
  95   R        "Universal gas constant (J/mol-K)" /8.314/
  96   Omega_a  "SRK parameter" /0.42747/
  97   Omega_b  "SRK parameter" /0.08664/
  98   Mw(i)    "Molecular weights (kg/kmol)" / 1 56.10752, 2 46.06904, 3 56.10752, 4 102.17656 /
  99   Pc(i)    "Critical pressure (Pa)"      / 1 4.02E6, 2 6.137E6, 3 4.0E6, 4 2.934E6 /
 100   Tc(i)    "Critical temperature (K)"    / 1 419.5, 2 514, 3 417.9, 4 509.4 /
 101   w(i)     "Acentric factor"             / 1 0.184495, 2 0.643558, 3 0.19484, 4 0.316231 /
 102   Tb(i)    "Boiling temperature (K)"     / 1 342.6, 2 421.5, 3 341.8, 4 441.4 /
 103   Hform(i) "Heat of formation (J/mol)"   / 1 -500, 2 -234950, 3 -17100, 4 -313900 /
 104   kappa(i) "SRK equation parameter"
 105   ac(i)    "Component-specific parameter"
 106   bii(i)   "SRK b-parameter"
 107   F_factor "Scaling factor (mol/min)"
 108   FH_factor  "Scaling factor for duty (J/min)"
 109   H_factor "Scaling factor for enthalpy (J/mol)"
 110   TF_factor "Scaling Temperature (K)"
 111  ;
 112   
 113  * ============================================================================ *
 114  * Enthalpy for two feeds
 115  * ============================================================================ *
 116   
 117  PARAMETERS
 118      HFB_d    "Enthalpy of butenos feed [J/mol]" /-21481.62933928521/
 119      HFE_d    "Enthalpy of ethanol feed [J/mol]" /-273241.2338487912/
 120      HFB      "Enthalpy of butenos feed [-]"
 121      HFE      "Enthalpy of ethanol feed [-]";
 122   
 123  *scaling factors
 124  F_factor = (1.7118+5.774);
 125  FH_factor = 1.7118*abs(HFE_d) + 5.774*abs(HFB_d);
 126  H_factor = F_factor/FH_factor;
 127  TF_factor = (342.38 + 325)/2;
 128   
 129  HFE = HFE_d*H_factor;
 130  HFB = HFB_d*H_factor;
 131  FB = 5.774/F_factor;
 132   
 133  * Calculate component-specific parameters
 134  kappa(i) = 0.480 + 1.574*w(i) - 0.176*w(i)**2;
 135  ac(i) = Omega_a * (R * Tc(i)) ** 2 / Pc(i);
 136  bii(i) = Omega_b * R * Tc(i) / Pc(i);
 137   
 138  * ============================================================================ *
 139  * ================================= VARIABLES ================================ *
 140  * ============================================================================ *
 141   
 142  POSITIVE VARIABLES
 143      L(j)        "Liquid molar flowrate (mol/min)"
 144      V(j)        "Vapor molar flowrate (mol/min)"
 145      x(i,j)      "Liquid molar fraction"
 146      y(i,j)      "Vapor molar fraction"
 147      T(j)        "Temperature (K)"
 148      D           "Destillate product flowrate (mol/min)"
 149      Qc          "Condenser Duty (J/min)"
 150      Qr          "Reboiler Duty (J/min)"
 151      FE          "Ethanol molar flowrate"
 152  ;
 153   
 154  * Explicit Lower Bounds to prevent Log(0) and Division by 0
 155  *T.lo(j) = 100;
 156  *bii.lo(i) = 1e-6;
 157   
 158  * ============================================================================ *
 159  * ================================= EQUATIONS ================================ *
 160  * ============================================================================ *
 161   
 162  EQUATION psat_def(i,j);
 163  POSITIVE VARIABLES logPsat(i,j) "Saturation Pressure (Pa)";
 164   
 165  PARAMETER kk(i,*) "psat antoine parameters";
 166  TABLE kk(i,*)
 167          1      2          3     4      5        6          7
 168  1    51.836  -4019.2      0     0   -4.5229   4.8833E-17   6
 169  2    73.304  -7122.3      0     0   -7.1424   2.8853E-06   2
 170  3    78.01   -4634.1      0     0   -8.9575   1.3413E-05   2
 171  4    64.188  -5820.2      0     0   -6.1343   2.1405E-17   6;
 172   
 173  psat_def(i,j)$(ord(j) <= Ns) ..
 174      logPsat(i,j) =E= (
 175           kk(i,'1') + kk(i,'2')/(kk(i,'3') + T(j))
 176           + kk(i,'4')*T(j) + kk(i,"5")*LOG(T(j))
 177           + kk(i,'6')*(T(j)**kk(i,'7')));
 178   
 179  * ============================================================================ *
 180  * Soave Redlich Kwong for Mixtures (phi_mix,HR_mix)
 181  * ============================================================================ *
 182   
 183  VARIABLES
 184      Z(j)          "Compressibility factor"
 185      v_mol(j)      "Molar volume"
 186      phi(i,j)      "Fugacity coefficient"
 187      HR(j)         "Residual enthalpy",
 188      alpha_ij(i,j) "Alpha parameter"
 189      aii(i,j)    "Component-wise SRK aii parameter"
 190      a(j)        "Mixture parameter a"
 191      b(j)        "Mixture parameter b"
 192      dadT_ii(i,j) "Partial derivative of a to T"
 193      dadT(j)     "Total temperature derivative of a";
 194   
 195  * Explicit Lower Bounds for SRK Variables
 196  *Z.lo(j) = 0.001;
 197  *v_mol.lo(j) = 0.0001;
 198  *b.lo(j) = 1e-6;
 199   
 200  PARAMETER P(j) "Pressure (Pa)";
 201  P(j) = 9.5e5;
 202   
 203  EQUATIONS
 204      cubic_eos,
 205      v_definition,
 206      fugacity_eq,
 207      enthalpy_eq,
 208      alpha_definition,
 209      aii_definition,
 210      mixing_rule_b,
 211      mixing_rule_a,
 212      dadT_ii_eq,
 213      dadT_eq;
 214   
 215  * Macro for make it easier to write the equations
 216  $macro Tr(i,j) ( T(j)/Tc(i) )
 217  $macro Betav(j) ( b(j) * P(j) ) / ( R*T(j) )
 218  $macro qv(j) ( a(j) / (b(j)*R*T(j) ) )
 219   
 220  cubic_eos(j)$(ord(j) <= Ns)  ..
 221      -Z(j) + 1 + ( b(j) * P(j) ) / ( R*T(j) ) - ( a(j) / (b(j)*R*T(j) ) ) * ( b(j) * P(j) ) / ( R*T(j) ) * ( Z(j) - ( b(j) * P(j) ) / ( R*T(j) ) ) / ( Z(j)*( Z(j) + ( b(j) * P(j) ) / ( R*T(j) ) ) ) =E= 0;
 222   
 223  alpha_definition(i,j)$(ord(j) <= Ns)  ..
 224      alpha_ij(i,j) =E= ( 1 + kappa(i) * ( 1 - sqrt(( T(j)/Tc(i) )) )  )**2;
 225   
 226  aii_definition(i,j)$(ord(j) <= Ns)  ..
 227      aii(i,j) =E= alpha_ij(i,j) * ac(i);
 228   
 229  mixing_rule_b(j)$(ord(j) <= Ns)  ..
 230      b(j) =E= SUM(i, y(i,j) * bii(i));
 231   
 232  ALIAS(i, k);
 233  mixing_rule_a(j)$(ord(j) <= Ns)  ..
 234      a(j) =E= SUM(i, SUM(k, y(i,j) * y(k,j) * sqrt(aii(i,j) * aii(k,j))));
 235   
 236  v_definition(j)$(ord(j) <= Ns)  ..
 237      v_mol(j) =E= Z(j)*R*T(j)/P(j);
 238   
 239  fugacity_eq(i,j)$(ord(j) <= Ns)  ..
 240      phi(i,j) =E= EXP(
 241          bii(i)*(Z(j)-1)/b(j) - log( P(j)*(v_mol(j)-b(j))/(R*T(j)) ) +
 242          (a(j)/(b(j)*R*T(j))) * ( bii(i)/b(j) - 2*SUM(k, y(k,j) * SQRT(aii(i,j) * aii(k,j)))/a(j)) * log((v_mol(j)+b(j))/v_mol(j))
 243      );
 244   
 245  dadT_ii_eq(i,j)$(ord(j) <= Ns)  ..
 246      dadT_ii(i,j) =E= -(ac(i) * kappa(i)) * sqrt(alpha_ij(i,j) * ( T(j)/Tc(i) )) / T(j);
 247   
 248  dadT_eq(j)$(ord(j) <= Ns)  ..
 249      dadT(j) =E= - SUM(i, SUM(k, y(i,j) * y(k,j) * sqrt(dadT_ii(i,j) * dadT_ii(k,j))));
 250   
 251  enthalpy_eq(j)$(ord(j) <= Ns)  ..
 252      HR(j) =E= R*T(j)*(Z(j)-1 + (T(j)*dadT(j) - a(j)) / (b(j)*R*T(j)) * log((v_mol(j) + b(j))/v_mol(j)));
 253   
 254  * ============================================================================ *
 255  * NRTL model
 256  * ============================================================================ *
 257   
 258  Parameters
 259      b_nrtl(i,i) /
 260          1.2  595.529982, 1.3 110.239086, 1.4 226.373398,
 261          2.1 164.57256,  2.3 141.963213, 2.4 187.104064,
 262          3.1 -95.4252161,3.2 623.581001, 3.4 219.73407,
 263          4.1 -177.88565, 4.2 344.481315, 4.3 -172.59152
 264      /
 265      c_nrtl(i,i) /
 266      1.1  0.0,  1.2  0.3,  1.3  0.3,  1.4  0.3,
 267      2.1  0.3,  2.2  0.0,  2.3  0.3,  2.4  0.3,
 268      3.1  0.3,  3.2  0.3,  3.3  0.0,  3.4  0.3,
 269      4.1  0.3,  4.2  0.3,  4.3  0.3,  4.4  0.0
 270      /;
 271   
 272  Alias(i,h);
 273  Alias(i,m);
 274   
 275  Variables
 276      gamma_nrtl(i,j);
 277   
 278  Equations
 279      Compute_gamma(i,j);
 280   
 281  $macro tao_nrtl(i,k,j)  ( b_nrtl(i,k) / T(j) )
 282  $macro g_nrtl(i,k,j) (exp(-c_nrtl(i,k) * ( b_nrtl(i,k) / T(j) ) ) )
 283   
 284  Compute_gamma(i,j)$(ord(j) <= Ns) ..
 285      gamma_nrtl(i,j) =E= exp(
 286          SUM(h, x(h,j) * ( b_nrtl(h,i) / T(j) ) * (exp(-c_nrtl(h,i) * ( b_nrtl(h,i) / T(j) ) ) )) /
 287          SUM(k, x(k,j) * (exp(-c_nrtl(k,i) * ( b_nrtl(k,i) / T(j) ) ) ))
 288      +
 289          SUM(h, (x(h,j) * (exp(-c_nrtl(i,h) * ( b_nrtl(i,h) / T(j) ) ) )) /
 290          SUM(k, x(k,j) * (exp(-c_nrtl(k,h) * ( b_nrtl(k,h) / T(j) ) ) )) *
 291          (( b_nrtl(i,h) / T(j) ) -
 292          SUM(m, x(m,j) * ( b_nrtl(m,h) / T(j) ) * (exp(-c_nrtl(m,h) * ( b_nrtl(m,h) / T(j) ) ) )) /
 293          SUM(k, x(k,j) * (exp(-c_nrtl(k,h) * ( b_nrtl(k,h) / T(j) ) ) ))))
 294          );
 295   
 296  * ============================================================================ *
 297  * Partition coeffient
 298  * ============================================================================ *
 299   
 300  Positive Variable K_part(i,j);
 301  Equation K_equation(i,j);
 302   
 303  K_equation(i,j)$(ord(j) <= Ns)  ..
 304      K_part(i,j)*(phi(i,j) * P(j)) =E= gamma_nrtl(i,j) * exp(logPsat(i,j));
 305   
 306  * ============================================================================ *
 307  * Enthalpy vapor phase
 308  * ============================================================================ *
 309   
 310  SET cc /1*5/;
 311  PARAMETERS C_ig(i,cc) Heat capacity coefficients for ideal gas;
 312   
 313  TABLE C_ig(i,cc)
 314         1              2              3              4              5
 315  1  111.022862   -0.750243683  0.00374664805  -6.16980174E-06   3.65183052E-09
 316  2   78.1195715  -0.495919524  0.00257066991  -4.30332398E-06   2.57806954E-09
 317  3  150.319619   -0.966221476  0.00404410804  -6.00376885E-06   3.23582716E-09
 318  4   47.4579586  -0.349114826  0.00180207897  -3.04885369E-06   1.83440907E-09;
 319   
 320  SCALAR T0 "Reference temperature [K]" /298.15/;
 321   
 322  VARIABLES DH_ig(i,j) "Ideal gas enthalpy change [J/mol]";
 323  VARIABLES Hvi(i,j) "Ideal gas enthlapy of vapor phase for component i + Hform[J/mol]";
 324  VARIABLES Hv(j) "Total vapor phase enthalpy";
 325   
 326  EQUATIONS calc_DH_ig, calc_Hvi, calc_Hv;
 327   
 328  calc_DH_ig(i,j) $(ord(j) <= Ns) ..
 329      DH_ig(i,j) =E= (C_ig(i,'1')*(T(j) - T0)
 330                 + C_ig(i,'2')*(T(j)**2 - T0**2)/2
 331                 + C_ig(i,'3')*(T(j)**3 - T0**3)/3
 332                 + C_ig(i,'4')*(T(j)**4 - T0**4)/4
 333                 + C_ig(i,'5')*(T(j)**5 - T0**5)/5);
 334   
 335  calc_Hvi(i,j) $(ord(j) <= Ns) ..
 336      Hvi(i,j) =E= DH_ig(i,j) + Hform(i);
 337   
 338  calc_Hv(j)$(ord(j) <= Ns) ..
 339      Hv(j)/H_factor =E= (sum(i, y(i,j) * Hvi(i,j)) + HR(j));
 340   
 341  * ============================================================================ *
 342  * Enthalpy liquid phase
 343  * ============================================================================ *
 344   
 345  PARAMETERS
 346      C_liq(i,cc) "Heat capacity coefficients for liquid phase",
 347      C_vap(i,cc) "DIPPR coefficients for vaporization enthalpy";
 348   
 349  TABLE C_liq(i,cc)
 350         1              2              3                  4                   5
 351  1  2.42239762e+05  -2.74746461e+03   1.16801221e+01  -2.20506997e-02   1.56048214e-05
 352  2  1.21280234e+03  -1.30223888e+01   5.71358761e-02  -1.12370042e-04   8.73258381e-08
 353  3  3.08689696e+05  -3.49815711e+03   1.48572135e+01  -2.80226414e-02   1.98131733e-05
 354  4  1.20736602e+03  -1.29812644e+01   5.93572571e-02  -1.16271343e-04   8.66983296e-08;
 355   
 356  TABLE C_vap(i,cc)
 357         1          2      3          4         5
 358  1   33774     0.5107    -0.17304   0.05181    0
 359  2   65831     1.1905    -1.7666    1.0012     0
 360  3   43172     1.5334    -1.9       0.83816    0
 361  4   45290     0.27343    0.21645  -0.11756    0;
 362   
 363  Parameter Tbr(i), alpha_Tb(i), ai_Tb, e, sigma;
 364   
 365  Tbr(i) = Tb(i)/Tc(i);
 366  Parameter DH_vap(i) "Vaporization enthalpy at Tb [J/mol]";
 367   
 368  DH_vap(i) = C_vap(i,'1')*(1 - Tbr(i))**(C_vap(i,'2')
 369              + C_vap(i,'3')*Tbr(i)
 370              + C_vap(i,'4')*Tbr(i)**2
 371              + C_vap(i,'5')*Tbr(i)**3);
 372   
 373  Parameter DH_ig_Tb(i) "DH_ig from T0 to TB [J/mol]";
 374  DH_ig_Tb(i) = C_ig(i,'1')*(Tb(i) - T0)
 375                 + C_ig(i,'2')*(sqr(Tb(i)) - sqr(T0))/2
 376                 + C_ig(i,'3')*(power(Tb(i),3) - power(T0,3))/3
 377                 + C_ig(i,'4')*(power(Tb(i),4) - power(T0,4))/4
 378                 + C_ig(i,'5')*(power(Tb(i),5) - power(T0,5))/5;
 379   
 380  VARIABLES DH_liq(i,j) "Liquid enthalpy change from Tb to T [J/mol]";
 381  VARIABLES Hv_Tbi_P(i,j) "Vapor phase enthalpy at Tb [J/mol]";
 382  VARIABLES Hli(i,j) "Liquid enthalpy for each component [J/mol]";
 383  VARIABLES Hl(j) "Total liquid phase enthalpy [J/mol]";
 384   
 385  * SRK for pure components at Tb
 386  alpha_Tb(i) = (1 + kappa(i) * (1 - Tbr(i) ** 0.5)) ** 2;
 387  ai_Tb(i) = alpha_Tb(i)*ac(i);
 388   
 389  *Cubic EOS - SRK
 390  Positive Variable Zvi(i,j), v_mol_i(i,j);
 391  Equation Zvi_eq(i,j), v_eq(i,j);
 392  Variable HR_pure(i,j) "Residual enthalpy for pure substance";
 393   
 394  * Explicit Lower Bounds for Pure SRK Variables
 395  *Zvi.lo(i,j) = 0.001;
 396  *v_mol_i.lo(i,j) = 0.0001;
 397   
 398  $macro Betav_p(i,j) ( bii(i)*P(j)/(R*Tb(i)) )
 399  $macro qv_p(i) ( ai_Tb(i) / (bii(i)*R*Tb(i)) )
 400   
 401  Zvi_eq(i,j) $(ord(j) <= Ns) ..
 402      -Zvi(i,j) + 1 + ( bii(i)*P(j)/(R*Tb(i)) ) - ( ai_Tb(i) / (bii(i)*R*Tb(i)) ) * ( bii(i)*P(j)/(R*Tb(i)) ) * ( Zvi(i,j) - ( bii(i)*P(j)/(R*Tb(i)) ) ) / ( Zvi(i,j)*( Zvi(i,j) + ( bii(i)*P(j)/(R*Tb(i)) ) ) ) =E= 0;
 403   
 404  v_eq(i,j) $(ord(j) <= Ns) ..
 405      v_mol_i(i,j) =E= Zvi(i,j)*R*Tb(i)/P(j);
 406   
 407  Parameter dadT_Tb(i);
 408  Equation calc_HR_pure(i,j);
 409  * NOTE: Zvi_eq_ideal and calc_HR_pure_ideal REMOVED
 410   
 411  dadT_Tb(i) = - ac(i)*kappa(i)*sqrt(alpha_Tb(i)*Tbr(i))/Tb(i);
 412   
 413  calc_HR_pure(i,j) $(ord(j) <= Ns) ..
 414      HR_pure(i,j) =E= R * Tb(i) * (Zvi(i,j) - 1 + (Tb(i) * dadT_Tb(i) - ai_Tb(i)) / (bii(i) * R * Tb(i)) * log((v_mol_i(i,j) + bii(i)) / v_mol_i(i,j)));
 415   
 416  EQUATIONS calc_DH_liq, calc_Hli, calc_Hl, calc_Hv_Tbi_P(i,j);
 417   
 418  calc_DH_liq(i,j) $(ord(j) <= Ns) ..
 419      DH_liq(i,j) =e= C_liq(i,'1')*(T(j) - Tb(i))
 420                 + C_liq(i,'2')*(T(j)**2 - Tb(i)**2)/2
 421                 + C_liq(i,'3')*(T(j)**3 - Tb(i)**3)/3
 422                 + C_liq(i,'4')*(T(j)**4 - Tb(i)**4)/4
 423                 + C_liq(i,'5')*(T(j)**5 - Tb(i)**5)/5;
 424   
 425  calc_Hv_Tbi_P(i,j) $(ord(j) <= Ns) ..
 426      Hv_Tbi_P(i,j) =E= DH_ig_Tb(i) + Hform(i) + HR_pure(i,j);
 427   
 428  calc_Hli(i,j) $(ord(j) <= Ns) ..
 429      Hli(i,j) =E= DH_liq(i,j) + Hv_Tbi_P(i,j) - DH_vap(i);
 430   
 431  calc_Hl(j)$(ord(j) <= Ns) ..
 432      Hl(j)/H_factor =E= sum(i, x(i,j) * Hli(i,j));
 433   
 434  * ============================================================================ *
 435  * Chemical reaction rate
 436  * ============================================================================ *
 437  PARAMETER reactive_trays(j);
 438   
 439  VARIABLES
 440      K_eq(j)       "Reaction equilibrium constant"
 441      k_rate(j)     "Specific reaction rate [mol/(kg_cat-min)]"
 442      k_A(j)        "Adsorption rate"
 443      Rxn_Rate(j)   "Reaction rate [mol/(kg_cat-min)]";
 444   
 445  $macro Xg(i,j) ( x(i,j)*gamma_nrtl(i,j) )
 446   
 447  EQUATION calc_K_eq(j);
 448  calc_K_eq(j)$((ord(j) = NR1) OR (ord(j) = NR2) OR (ord(j) = NR3)) ..
 449      K_eq(j) =E= EXP(10.387 + 4060.59/T(j) - 2.89055*LOG(T(j)) - 0.01915144*T(j) + 5.28586E-5*T(j)**2);
 450   
 451   
 452   
 453  * ============================================================================ *
 454  * Column Diameter Calculation
 455  * ============================================================================ *
 456  VARIABLE
 457      D_col(j)        'Column diameter (ft)'
 458      Dcol_max        'Maximum column diameter (ft)'
 459      Mw_mix(j)       'Molecular weights (kg/kmol)';
 460   
 461  EQUATION
 462      def_D_col(j)    'Equation for column diameter calculation'
 463      def_Mw_mix(j)   'Define mixture molar mass at stage j'
 464      def_Dcol_max(j) 'Equation for maximum column diameter calculation';
 465   
 466  SCALAR FF 'Parameter for flooding velocity estimation' ;
 467   
 468  FF = 1.51*(0.45359237/0.3048)**0.5;
 469  * Prevent Dcol_max from hitting 0 for the **1.066 exponential
 470  Dcol_max.lo = 0.1;
 471   
 472  def_Mw_mix(j)$(ord(j) <= Ns) ..
 473      Mw_mix(j) =E= sum(i, y(i,j)*Mw(i));
 474   
 475  * Expanding the macros into the equation safely
 476  def_D_col(j)$( (ord(j) > 1) AND (ord(j) < Ns) ) ..
 477      D_col(j) =E= sqrt(4 * ( (V(j)*F_factor*v_mol(j)/60) / ( (FF/sqrt(Mw_mix(j)*1e-3/v_mol(j))) * 0.88 ) ) / Pi) * 3.28084;
 478   
 479  def_Dcol_max(j)$( (ord(j) > 1) AND (ord(j) < Ns) ) ..
 480      Dcol_max =G= D_col(j);
 481   
 482  * ============================================================================ *
 483  * Equipment Costs & Economics (Refactored for NLP)
 484  * ============================================================================ *
 485  SCALAR MS "Marshall & Swift Parameter" /1773.4/;
 486   
 487  PARAMETERS
 488      CostETBE "Price of ETBE bottom product [$/mol]" / 25.3e-3 /
 489      CostEth  "Price of Ethanol [$/mol]"             / 15.0e-3 /
 490      CostBut  "Price of Butenes [$/mol]"             / 8.25e-3 /
 491      c_steam  "Steam cost parameter"                 / 4.54e-9 /;
 492   
 493  VARIABLES
 494      Tcond         "Condenser temperature (K)"
 495      Treb          "Reboiler Temperature (K)"
 496      Breb          "Bottoms flowrate"
 497      v_AreaCond    "Condenser heat transfer area (ft2)"
 498      v_AreaReb     "Reboiler heat transfer area (ft2)"
 499      v_ColCost     "Column shell cost ($)"
 500      v_TrayCost    "Tray cost ($)"
 501      v_CondCost    "Condenser cost ($)"
 502      v_RebCost     "Reboiler cost ($)"
 503      CAP_cost      "Capital cost ($/yr)"
 504      OP_cost       "Operational cost ($/yr)"
 505      Profit        "Annual Profit (Millions $)";
 506   
 507  EQUATIONS
 508      def_Tcond, def_Treb(j), def_Breb(j),
 509      eq_AreaCond, eq_AreaReb,
 510      eq_ColCost, eq_TrayCost, eq_CondCost, eq_RebCost,
 511      eq_CAP_cost, eq_OP_cost, def_Profit;
 512   
 513  * --- CRITICAL BOUNDS TO PREVENT SOLVER CRASHES ---
 514  Tcond.lo = 315;
 515  Treb.up = Tmax;
 516  v_AreaCond.lo = .1;
 517  v_AreaReb.lo = .1;
 518  v_AreaCond.up = 5;
 519  v_AreaReb.up = 5;
 520   
 521  def_Tcond ..
 522      Tcond =E= T('1');
 523   
 524  def_Treb(j)$(ord(j) = Ns) ..
 525      Treb =E= T(j);
 526   
 527  def_Breb(j)$(ord(j) = Ns) ..
 528      Breb =E= L(j);
 529   
 530  * Area Calculations
 531  eq_AreaCond ..
 532      v_AreaCond =E= (Qc*FH_factor/60) / ( (150/0.17611) * (10 / log((Tcond-303.15)/(Tcond-313.15))) ) * 10.7639;
 533   
 534  eq_AreaReb ..
 535      v_AreaReb =E= (Qr*FH_factor/60) / ( (250/0.17611) * (433.15 - Treb) ) * 10.7639;
 536   
 537  * Capital Costs
 538  eq_ColCost ..
 539      v_ColCost =E= (MS/280) * ( 101.9 * (Dcol_max**1.066) * ((0.7315*(Ns-2)*3.28084)**0.802) * 7.05 );
 540   
 541  eq_TrayCost ..
 542      v_TrayCost =E= (MS/280) * ( 4.7 * (Dcol_max**1.55) * (0.7315*(Ns-2)*3.28084) * 2.7 );
 543   
 544  eq_CondCost ..
 545      v_CondCost =E= (MS/280) * 101.3 * 2.665 * (v_AreaCond**0.65);
 546   
 547  eq_RebCost ..
 548      v_RebCost =E= (MS/280) * 101.3 * (v_AreaReb**0.65) * 7.3525;
 549   
 550  eq_CAP_cost ..
 551      CAP_cost =E= (1/3) * (v_TrayCost + v_ColCost + v_CondCost + v_RebCost + (7.7*3*0.4));
 552   
 553  * Operational Costs
 554  eq_OP_cost ..
 555      OP_cost =E= (0.378e-9*Qc + c_steam*Qr) * 8150 * 60 * FH_factor +
 556                  (FE*CostEth + FB*CostBut - CostETBE*Breb) * F_factor * 8150 * 60;
 557   
 558  * Objective Function
 559  def_Profit ..
 560      Profit * 1e6 =E= CAP_cost + OP_cost;
 561   
 562  EQUATION obj_def;
 563  VARIABLE obj;
 564   
 565  obj_def ..
 566      obj =E= Profit;
 567   
 568  * Positive Variables
 569  L.lo(j) = 1e-5 ;  L.up(j) = 50; L.l(j) = .5;
 570  V.lo(j) = 1e-5 ;  V.up(j) = 50; V.l(j) = .5;
 571  V.lo('1') = 0; V.up('1') = 0.001; V.l('1') = 0;
 572  x.lo(i,j) = 0;  x.up(i,j) = 1; x.l(i,j) = 0.25;
 573  y.lo(i,j) = 0;  y.up(i,j) = 1; y.l(i,j) = 0.25;
 574  D.lo = 0.01; D.up = 1;
 575  Qc.lo = 0.01;  Qc.up = 10;
 576  Qr.lo = 0.01;  Qr.up = 10;
 577  Breb.lo = 0.001; Breb.up = 1;
 578  T.lo(j) = Tmin; T.up(j) = Tmax; T.scale(j) = TF_factor;
 579   
 580  logPsat.lo(i,j) = (
 581                  kk(i,'1') + kk(i,'2')/(kk(i,'3') + Tmin)
 582                 + kk(i,'4')*Tmin + kk(i,"5")*LOG(Tmin)
 583                 + kk(i,'6')*(Tmin**kk(i,'7')));
 584   
 585   
 586  logPsat.up(i,j) = (
 587                  kk(i,'1') + kk(i,'2')/(kk(i,'3') + Tmax)
 588                 + kk(i,'4')*Tmax + kk(i,"5")*LOG(Tmax)
 589                 + kk(i,'6')*(Tmax**kk(i,'7')));
 590  logPsat.scale(i,j) = 10;
 591   
 592  * Apply linear profile
 593  *    jmax = Ns;
 594  *    T.L(j) = Tmin + (ord(j) - jmin) / (jmax - jmin) * (Tmax - Tmin);
 595  *                    T.L(j) = Tmin + (ord(j) - jmin) / (jmax - jmin) * (Tmax - Tmin);
 596   
 597  * SRK parameters and properties
 598  *dadT_Tb.lo(i) = -0.01; dadT_Tb.up(i) = -0.00001;
 599   
 600  alpha_ij.lo(i,j) = 0.5;  alpha_ij.up(i,j) = 2;
 601  aii.lo(i,j) = 1;  aii.up(i,j) = 4;
 602  a.lo(j) = 1;  a.up(j) = 3;
 603  b.lo(j) = 1e-5;  b.up(j) = 1e-3; b.scale(j) = 1e-5;
 604  dadT_ii.lo(i,j) = -0.009;  dadT_ii.up(i,j) = -0.001; dadT_ii.scale(i,j) = 1e-3;
 605  dadT.lo(j) = -0.009;  dadT.up(j) = -0.001; dadT.scale(j) = 1e-3;
 606  K_part.lo(i,j) = 0.001 ; K_part.up(i,j) = 10;
 607  phi.lo(i,j) = 0.1; phi.up(i,j) = 1.2;
 608   
 609  *    *Enthalpy Variables
 610  DH_ig.lo(i,j) = (C_ig(i,'1')*(Tmin - T0)
 611                 + C_ig(i,'2')*(Tmin**2 - T0**2)/2
 612                 + C_ig(i,'3')*(Tmin**3 - T0**3)/3
 613                 + C_ig(i,'4')*(Tmin**4 - T0**4)/4
 614                 + C_ig(i,'5')*(Tmin**5 - T0**5)/5);
 615  DH_ig.up(i,j) = (C_ig(i,'1')*(Tmax - T0)
 616                 + C_ig(i,'2')*(Tmax**2 - T0**2)/2
 617                 + C_ig(i,'3')*(Tmax**3 - T0**3)/3
 618                 + C_ig(i,'4')*(Tmax**4 - T0**4)/4
 619                 + C_ig(i,'5')*(Tmax**5 - T0**5)/5);
 620  DH_ig.scale(i,j) = 1e3;
 621   
 622  Hvi.lo(i,j) = DH_ig.lo(i,j) + Hform(i);
 623  Hvi.up(i,j) = DH_ig.up(i,j) + Hform(i);
 624  Hvi.scale(i,j) = 1e5;
 625   
 626  HR.lo(j) = -2500;  HR.up(j) = -1100; HR.scale(j) = 1e3;
 627   
 628  Hv.lo(j) = ( smin(i, Hvi.lo(i,j)) + HR.lo(j) ) * H_factor;
 629  Hv.up(j) = ( smax(i, Hvi.up(i,j)) + HR.up(j) ) * H_factor;
 630   
 631   
 632  DH_liq.lo(i,j) = C_liq(i,'1')*(Tmin - Tb(i))
 633                  + C_liq(i,'2')*(Tmin**2 - Tb(i)**2)/2
 634                  + C_liq(i,'3')*(Tmin**3 - Tb(i)**3)/3
 635                  + C_liq(i,'4')*(Tmin**4 - Tb(i)**4)/4
 636                  + C_liq(i,'5')*(Tmin**5 - Tb(i)**5)/5;
 637  DH_liq.up(i,j) = C_liq(i,'1')*(Tmax - Tb(i))
 638                  + C_liq(i,'2')*(Tmax**2 - Tb(i)**2)/2
 639                  + C_liq(i,'3')*(Tmax**3 - Tb(i)**3)/3
 640                  + C_liq(i,'4')*(Tmax**4 - Tb(i)**4)/4
 641                  + C_liq(i,'5')*(Tmax**5 - Tb(i)**5)/5;
 642  DH_liq.scale(i,j) = 1e4;
 643   
 644  HR_pure.lo(i,j) = -3e3;  HR_pure.up(i,j) = -1e3; HR_pure.scale(i,j) = 1e3;
 645  Hv_Tbi_P.lo(i,j) = DH_ig_Tb(i)*0.99 + Hform(i) + HR_pure.lo(i,j);
 646  Hv_Tbi_P.up(i,j) = DH_ig_Tb(i)*1.01 + Hform(i) + HR_pure.up(i,j);
 647  Hv_Tbi_P.scale(i,j) = 1e4;
 648   
 649  Hli.lo(i,j) = DH_liq.lo(i,j) + Hv_Tbi_P.lo(i,j) - DH_vap(i);
 650  Hli.up(i,j) = DH_liq.up(i,j) + Hv_Tbi_P.up(i,j) - DH_vap(i);
 651  Hli.scale(i,j) = 1e5;
 652   
 653  Hl.lo(j) = smin(i, Hvi.lo(i,j)) * H_factor;
 654  Hl.up(j) = smax(i, Hvi.up(i,j)) * H_factor;
 655   
 656  *    * molar volume
 657  Z.lo(j) = 0.75; Z.up(j) = 0.9; Z.l(j) = 0.822;
 658  v_mol.lo(j) = Z.lo(j)*R*Tmin/(9.5e5);
 659  v_mol.up(j) = Z.up(j)*R*Tmax/(9.5e5);
 660  v_mol.scale(j) = 1e-3;
 661   
 662  Zvi.lo(i,j) = 0.75; Zvi.up(i,j) = 1;  Zvi.l(i,j) = 0.9;
 663  v_mol_i.lo(i,j) = Zvi.lo(i,j)*R*Tmin/(9.5e5);
 664  v_mol_i.up(i,j) = Zvi.up(i,j)*R*Tmax/(9.5e5);
 665  v_mol_i.scale(i,j) = 1e-3;
 666   
 667  *    * NRTL Parameters
 668  gamma_nrtl.lo(i,j) =  0.01;  gamma_nrtl.up(i,j) = 20;
 669  *    *tao_nrtl.lo(i,k,j) =-5; tao_nrtl.up(i,k,j) = 5; tao_nrtl.l(i,k,j) = 1;
