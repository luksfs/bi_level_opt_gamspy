 676  K_eq.up(j) = EXP(10.387 + 4060.59/Tmin - 2.89055*LOG(Tmin) - 0.01915144*Tmin + 5.28586E-5*Tmin**2 - 5.32977E-8*Tmin**3);
 677  K_eq.scale(j) = 10;
